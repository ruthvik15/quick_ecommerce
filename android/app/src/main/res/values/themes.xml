<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Compose -->
    <style name="Base.Theme.RiderApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_dark</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/primary</item>
    </style>

    <style name="Theme.RiderApp" parent="Base.Theme.RiderApp" />
    
    <!-- Splash Screen Theme -->
    <style name="Theme.App.Splash" parent="Theme.RiderApp">
        <item name="android:windowBackground">@color/primary</item>
    </style>
</resources>
